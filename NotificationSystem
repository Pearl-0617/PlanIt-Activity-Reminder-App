import java.awt.*;
import java.awt.TrayIcon.MessageType;
import java.time.LocalDateTime;
import java.time.format.DateTimeFormatter;
import java.time.Duration;
import java.util.Timer;
import java.util.TimerTask;

class NotificationSystem {

    public void scheduleNotif(ActivityReminder reminder) {
        validateReminder(reminder);

        LocalDateTime reminderTime = LocalDateTime.parse(
            reminder.getDate() + "T" + reminder.getTime(),
            DateTimeFormatter.ofPattern("yyyy-MM-dd'T'HH:mm")
        );

        long delay = Duration.between(LocalDateTime.now(), reminderTime).toMillis();

        if (delay < 0) {
            throw new IllegalArgumentException("Reminder time is in the past!");
        }

        Timer timer = new Timer();
        timer.schedule(new TimerTask() {
            @Override
            public void run() {
                sendNotif(reminder);
            }
        }, delay);
    }

    public void sendNotif(ActivityReminder reminder) {
        validateReminder(reminder);
        
        if (!SystemTray.isSupported()) {
            System.out.println("System tray not supported. Using console fallback:");
            System.out.println(" " + reminder.getTitle() + " - " + reminder.getDescription());
            return;
        }

        try {
            SystemTray tray = SystemTray.getSystemTray();

            Image image = Toolkit.getDefaultToolkit().createImage("notification.png");

            TrayIcon trayIcon = new TrayIcon(image, "PlanIt");
            trayIcon.setImageAutoSize(true);
            trayIcon.setToolTip("PlanIt Reminder System");

            tray.add(trayIcon);

            trayIcon.displayMessage(
                    reminder.getTitle(),
                    reminder.getDescription() +
                            "\nDate: " + reminder.getDate() +
                            " Time: " + reminder.getTime(),
                    MessageType.INFO
            );

        } catch (Exception e) {
            e.printStackTrace();
        }
    }
    private void validateReminder(ActivityReminder reminder) {
    if (reminder == null) {
            throw new IllegalArgumentException("Reminder cannot be null");
        }
        
        if (reminder.getTitle() == null || reminder.getTitle().isEmpty()) {
            throw new IllegalArgumentException("Title cannot be empty");
        }
        
        if (reminder.getDescription() == null || reminder.getDescription().isEmpty()) {
            throw new IllegalArgumentException("Description cannot be empty");
        }
        
        if (reminder.getDate() == null || reminder.getDate().isEmpty()) {
            throw new IllegalArgumentException("Date cannot be empty");
        }
        
        if (reminder.getTime() == null || reminder.getTime().isEmpty()) {
            throw new IllegalArgumentException("Time cannot be empty");
        }
    }
}
