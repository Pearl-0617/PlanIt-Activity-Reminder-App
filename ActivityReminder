import java.util.ArrayList;
import java.util.List;

class ActivityReminder {

  private int reminderId;
    private String title;
    private String description;
    private String date;
    private String time;
    private boolean isCompleted;

  public ActivityReminder(int reminderId, String title, String description, String date, String time) {
        this.reminderId = reminderId;
        this.title = title;
        this.description = description;
        this.date = date;
        this.time = time;
        this.isCompleted = false;
    }

  public int getReminderId() {
        return reminderId;
    }

    public String getTitle() {
        return title;
    }

    public String getDescription() {
        return description;
    }

    public String getDate() {
        return date;
    }

    public String getTime() {
        return time;
    }

    public boolean isCompleted() {
        return isCompleted;
    }

  public void setTitle(String title) {
        this.title = title;
    }

    public void setDescription(String description) {
        this.description = description;
    }

    public void setDate(String date) {
        this.date = date;
    }

    public void setTime(String time) {
        this.time = time;
    }

  public void editDetails(String newTitle, String newDescription, String newDate, String newTime) {
        this.title = newTitle;
        this.description = newDescription;
        this.date = newDate;
        this.time = newTime;
        System.out.println("Details Updated!");
    }

  public void markAsCompleted() {
        this.isCompleted = true;
        System.out.println("Completed!");
    }
}


